#!/usr/bin/env bash
# Real git pre-push gate. Blocks the push if homework-6 test coverage < 80%.
# Scoped: only enforces when the push includes changes under homework-6/ (so pushes that
# touch only other homeworks are not blocked).
#
# Install once per clone:  git config core.hooksPath homework-6/.githooks
set -uo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
GATE="$REPO_ROOT/homework-6/scripts/coverage-gate.sh"
ZERO="0000000000000000000000000000000000000000"

touched_hw6=0
while read -r local_ref local_sha remote_ref remote_sha; do
  [ -z "${local_sha:-}" ] && continue
  [ "$local_sha" = "$ZERO" ] && continue   # branch deletion
  if [ -z "${remote_sha:-}" ] || [ "$remote_sha" = "$ZERO" ]; then
    files="$(git diff-tree --no-commit-id --name-only -r "$local_sha" 2>/dev/null)"
  else
    files="$(git diff --name-only "$remote_sha" "$local_sha" 2>/dev/null)"
  fi
  if printf '%s\n' "$files" | grep -q '^homework-6/'; then
    touched_hw6=1
  fi
done

if [ "$touched_hw6" -eq 1 ]; then
  echo "[pre-push] homework-6 changes detected — enforcing coverage gate"
  exec bash "$GATE"
fi

echo "[pre-push] no homework-6 changes — coverage gate skipped"
exit 0
